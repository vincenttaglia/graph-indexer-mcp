{
  "name": "graph-indexer-mcp",
  "version": "0.1.0",
  "description": "MCP server for managing Graph Protocol indexer operations",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "graph-indexer-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "rm -rf dist-test && tsc -p tsconfig.test.json && node --test --test-isolation=none --experimental-test-coverage 'dist-test/test/**/*.test.js'"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "graphql": "^16.11.0",
    "graphql-request": "^7.4.0",
    "pg": "^8.21.0",
    "yaml": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.15.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.8.0"
  }
}
