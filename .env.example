# =============================================================================
# graph-indexer-mcp — example configuration
#
# Copy to .env and replace placeholders. See src/config.ts for the canonical
# schema; this file mirrors it. Required vars have no defaults — the
# entrypoint will refuse to start if any are missing.
# =============================================================================

# --- Required: indexer identity ---------------------------------------------
# 0x-prefixed 40-character hex address of the indexer this MCP serves.
INDEXER_ADDRESS=0x0000000000000000000000000000000000000000

# --- Required: data source endpoints ----------------------------------------
# Graph Network subgraph (allocations, indexing rewards, etc.).
NETWORK_SUBGRAPH_URL=https://gateway.thegraph.com/api/REPLACE_KEY/subgraphs/id/REPLACE_NETWORK_SUBGRAPH_ID
# Epoch Block Oracle subgraph (epoch boundaries).
EBO_SUBGRAPH_URL=https://gateway.thegraph.com/api/REPLACE_KEY/subgraphs/id/REPLACE_EBO_SUBGRAPH_ID
# Quality of Service subgraph (gateway QoS metrics).
QOS_SUBGRAPH_URL=https://gateway.thegraph.com/api/REPLACE_KEY/subgraphs/id/REPLACE_QOS_SUBGRAPH_ID
# graph-node status endpoint (indexing progress, errors).
GRAPH_NODE_STATUS_URL=http://localhost:8030/graphql
# indexer-agent GraphQL endpoint (cost models, rules).
INDEXER_AGENT_URL=http://localhost:18000/graphql
# graphman HTTP API (subgraph mgmt, rewinds, drops).
GRAPHMAN_API_URL=http://localhost:8050
# Bearer token for the graphman HTTP API. REQUIRED — keep this secret.
GRAPHMAN_AUTH_TOKEN=replace-with-graphman-bearer-token

# --- Optional: graphman CLI fallback (kubectl exec) -------------------------
# Used when the HTTP API doesn't cover an operation. Requires kubectl on PATH
# AND a kubeconfig that can pods/exec into the graph-node pod.
# GRAPHMAN_KUBECTL_NAMESPACE=default
# GRAPHMAN_POD_LABEL=app=graph-node
# GRAPHMAN_CONFIG_PATH=/etc/graph-node/config.toml

# --- Optional: graph-node Postgres (read-only) ------------------------------
# Enables subgraph_size disk-usage tools. Use READ-ONLY credentials — the
# MCP must never write to graph-node's index DB directly. Omit to disable.
# GRAPH_NODE_POSTGRES_URL=postgresql://readonly:password@localhost:5432/graph-node?sslmode=require

# --- Optional: access control -----------------------------------------------
# read_only | read_write | read_write_destructive | full   (default read_write)
# ACCESS_LEVEL=read_write
# Comma-separated tool names. Allow grants even if level would deny.
# ACCESS_OVERRIDES_ALLOW=
# Comma-separated tool names. Deny blocks even if level would allow.
# ACCESS_OVERRIDES_DENY=graphman_drop_deployment,graphman_rewind_deployment

# --- Optional: optimization parameters --------------------------------------
# Protocol network the indexer-agent submits against (Horizon: arbitrum-one).
# PROTOCOL_NETWORK=arbitrum-one

# Defaults shown; uncomment to override.
# MAX_ALLOCATIONS=15
# MAX_ALLOCATION_PCT=0.25
# RISKY_DEPLOYMENT_CAP_PCT=0.05
# MIN_SIGNAL=100
# GAS_ESTIMATE_GRT=0.3
# MIN_REWARDS_GRT_28D=10

# --- Optional: deployment lists (comma-separated IPFS hashes) ---------------
# WHITELIST=
# BLACKLIST=
# FROZENLIST=
# RISKY_DEPLOYMENTS=
