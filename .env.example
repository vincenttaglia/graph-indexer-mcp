# =============================================================================
# Graph Indexer MCP — Configuration
# Copy to .env and fill in values. See graph-indexer-mcp-design.md §8.
# =============================================================================

# --- Indexer identity ---
INDEXER_ADDRESS=0x0000000000000000000000000000000000000000

# --- Data source endpoints ---
NETWORK_SUBGRAPH_URL=https://gateway.thegraph.com/api/KEY/subgraphs/id/DEPLOYMENT_ID
EBO_SUBGRAPH_URL=https://gateway.thegraph.com/api/KEY/subgraphs/id/EBO_DEPLOYMENT_ID
QOS_SUBGRAPH_URL=https://gateway.thegraph.com/api/KEY/subgraphs/id/QOS_DEPLOYMENT_ID
GRAPH_NODE_STATUS_URL=http://localhost:8030/graphql
INDEXER_AGENT_URL=http://localhost:18000/graphql
GRAPHMAN_API_URL=http://localhost:8050
GRAPHMAN_AUTH_TOKEN=replace-with-graphman-bearer-token

# --- Graphman CLI fallback (kubectl exec) ---
GRAPHMAN_KUBECTL_NAMESPACE=default
GRAPHMAN_POD_LABEL=app=graph-node
GRAPHMAN_CONFIG_PATH=/etc/graph-node/config.toml

# --- Graph Node Postgres (read-only, for subgraph disk-size queries) ---
# Optional: omit to disable subgraph_size tools.
GRAPH_NODE_POSTGRES_URL=postgresql://readonly:password@localhost:5432/graph-node

# --- Access control ---
# read_only | read_write | read_write_destructive | full
ACCESS_LEVEL=read_write
# Comma-separated tool names. Allow grants even if level would deny.
ACCESS_OVERRIDES_ALLOW=
# Comma-separated tool names. Deny blocks even if level would allow.
ACCESS_OVERRIDES_DENY=

# --- Optimization parameters ---
MAX_ALLOCATIONS=15
MAX_ALLOCATION_PCT=0.25
RISKY_DEPLOYMENT_CAP_PCT=0.05
MIN_SIGNAL=100
GAS_ESTIMATE_GRT=50

# --- Lists (comma-separated deployment IPFS hashes) ---
WHITELIST=
BLACKLIST=
FROZENLIST=
RISKY_DEPLOYMENTS=
