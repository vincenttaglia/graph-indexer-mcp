# =============================================================================
# Sensitive configuration. COPY THIS FILE to k8s/secret.yaml, fill in real
# values, then `kubectl apply -f k8s/secret.yaml`. The .example suffix keeps
# the placeholders out of `kubectl apply -f k8s/` runs.
#
# DO NOT commit the populated secret.yaml — k8s/secret.yaml is gitignored at
# the repo root. Prefer External Secrets / sealed-secrets / Vault for
# production rather than raw Secret objects.
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: graph-indexer-mcp-secrets
  namespace: graph-indexer-mcp
  labels:
    app.kubernetes.io/name: graph-indexer-mcp
type: Opaque
stringData:
  # Bearer token for the graphman HTTP API. Required.
  GRAPHMAN_AUTH_TOKEN: "REPLACE_WITH_GRAPHMAN_BEARER_TOKEN"

  # Read-only postgres credentials for graph-node's index database. Optional;
  # omit (or leave commented in the Deployment envFrom) to disable the
  # subgraph_size tools. MUST use read-only credentials — the MCP never writes
  # to graph-node's database directly.
  GRAPH_NODE_POSTGRES_URL: "postgresql://readonly:REPLACE_PASSWORD@graph-node-postgres.graph-node.svc.cluster.local:5432/graph-node?sslmode=require"

  # --- Gateway subgraph URLs (contain API keys in the path) ---
  # The Graph gateway URL format is /api/<API_KEY>/subgraphs/id/<ID>. The key
  # segment is secret material, so these URLs live in the Secret rather than
  # the ConfigMap. If you self-host these subgraphs with no key in the URL,
  # you may move them to k8s/configmap.yaml instead (and delete them here —
  # envFrom precedence between ConfigMap and Secret for the same key is
  # undefined).
  NETWORK_SUBGRAPH_URL: "https://gateway.thegraph.com/api/REPLACE_KEY/subgraphs/id/REPLACE_NETWORK_SUBGRAPH_ID"
  EBO_SUBGRAPH_URL: "https://gateway.thegraph.com/api/REPLACE_KEY/subgraphs/id/REPLACE_EBO_SUBGRAPH_ID"
  QOS_SUBGRAPH_URL: "https://gateway.thegraph.com/api/REPLACE_KEY/subgraphs/id/REPLACE_QOS_SUBGRAPH_ID"
